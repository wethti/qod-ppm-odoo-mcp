# Odoo connection (required)
ODOO_URL=http://localhost:8069
ODOO_DB=qod_ppm
ODOO_USERNAME=ppm-service-user@example.com

# One of ODOO_API_KEY (preferred) or ODOO_PASSWORD
ODOO_API_KEY=
# ODOO_PASSWORD=

# Transport: "stdio" (default) or "http"
QOD_PPM_MCP_TRANSPORT=stdio
# Only used when transport=http
QOD_PPM_MCP_HOST=127.0.0.1
QOD_PPM_MCP_PORT=8765

# Optional: request timeout for Odoo JSON-RPC calls, in seconds
ODOO_TIMEOUT=30
